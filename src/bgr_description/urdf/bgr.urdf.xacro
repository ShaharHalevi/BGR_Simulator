<?xml version="1.0"?>
<robot name="bgr" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:arg name="is_ignition" default="true"/>

  <xacro:include filename="$(find bgr_description)/urdf/bgr_gazebo.xacro"/>
  <xacro:include filename="$(find bgr_description)/urdf/bgr_ros2_control.xacro"/>

  <xacro:property name="wheel_radius" value="0.24"/>
  <xacro:property name="wheel_width"  value="0.12"/>
  <xacro:property name="track"         value="1.3092"/>   
  <xacro:property name="wheelbase"     value="2.0368"/>   
  <xacro:property name="body_mass"     value="286.0"/>
  <xacro:property name="steer_limit"  value="0.384"/>   

  <xacro:property name="motor_inertia_kgm2" value="0.000274"/>
  <xacro:property name="gear_ratio"           value="11.5"/>
  <xacro:property name="reflected_inertia"    value="${motor_inertia_kgm2 * gear_ratio * gear_ratio}"/>

  <xacro:property name="ixx_val"  value="55.801289"/>
  <xacro:property name="iyy_val"  value="181.382241"/>
  <xacro:property name="izz_val"  value="199.609647"/>
  <xacro:property name="ixy_val"  value="-0.288597"/>
  <xacro:property name="ixz_val"  value="-8.267511"/>
  <xacro:property name="iyz_val"  value="-0.015345"/>

  <xacro:property name="body_size_x"  value="2.0"/>
  <xacro:property name="body_size_y"  value="1.0"/>
  <xacro:property name="body_size_z"  value="0.5"/>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${body_mass}"/>
      <inertia ixx="${ixx_val}" iyy="${iyy_val}" izz="${izz_val}"
               ixy="${ixy_val}" ixz="${ixz_val}" iyz="${iyz_val}"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://bgr_description/meshes/visual/base_link.STL"/></geometry>
      <material name="blue_grey">
          <color rgba="0.79216 0.81961 0.93333 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${body_size_z/2}" rpy="0 0 0"/>
      <geometry><box size="${body_size_x} ${body_size_y} ${body_size_z}"/></geometry>
    </collision>
  </link>

  <xacro:macro name="wheel_link" params="name visual_mesh">
    <link name="${name}">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="5.0"/>
        <inertia 
          ixx="${(1.0/12.0)*5.0*(3*wheel_radius*wheel_radius + wheel_width*wheel_width) + reflected_inertia}"
          iyy="${(1.0/12.0)*5.0*(3*wheel_radius*wheel_radius + wheel_width*wheel_width) + reflected_inertia}"
          izz="${(0.5*5.0*wheel_radius*wheel_radius) + reflected_inertia}"
          ixy="0" ixz="0" iyz="0"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><mesh filename="${visual_mesh}"/></geometry>
        <material name="blue_grey">
            <color rgba="0.79216 0.81961 0.93333 1"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
    </link>
  </xacro:macro>

  <xacro:macro name="stub_link" params="name">
    <link name="${name}">
      <inertial>
        <mass value="0.01"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><cylinder radius="0.01" length="0.02"/></geometry>
      </visual>
    </link>
  </xacro:macro>

  <xacro:wheel_link name="Wheel_rl" visual_mesh="package://bgr_description/meshes/visual/Wheel_rl.STL"/>
  <xacro:wheel_link name="Wheel_rr" visual_mesh="package://bgr_description/meshes/visual/Wheel_rr.STL"/>

  <xacro:stub_link name="Steering_fl"/>
  <xacro:wheel_link name="Wheel_fl" visual_mesh="package://bgr_description/meshes/visual/Wheel_fl.STL"/>
  <xacro:stub_link name="Steering_fr"/>
  <xacro:wheel_link name="Wheel_fr" visual_mesh="package://bgr_description/meshes/visual/Wheel_fr.STL"/>

  <joint name="Wheel_rl_joint" type="continuous">
    <origin xyz="${-wheelbase/2} ${track/2} -${wheel_radius}" rpy="0 0 0"/>
    <parent link="base_link"/><child link="Wheel_rl"/><axis xyz="0 1 0"/>
    <limit effort="300" velocity="100"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <joint name="Wheel_rr_joint" type="continuous">
    <origin xyz="${-wheelbase/2} ${-track/2} -${wheel_radius}" rpy="0 0 0"/>
    <parent link="base_link"/><child link="Wheel_rr"/><axis xyz="0 1 0"/>
    <limit effort="300" velocity="100"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <joint name="Steering_fl_joint" type="revolute">
    <origin xyz="${wheelbase/2} ${track/2} -${wheel_radius}" rpy="0 0 0"/>
    <parent link="base_link"/><child link="Steering_fl"/><axis xyz="0 0 1"/>
    <limit lower="${-steer_limit}" upper="${steer_limit}" effort="200" velocity="2.0"/>
    <dynamics damping="1.5" friction="0.1"/>
  </joint>

  <joint name="Wheel_fl_joint" type="continuous">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="Steering_fl"/><child link="Wheel_fl"/><axis xyz="0 1 0"/>
    <limit effort="300" velocity="100"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <joint name="Steering_fr_joint" type="revolute">
    <origin xyz="${wheelbase/2} ${-track/2} -${wheel_radius}" rpy="0 0 0"/>
    <parent link="base_link"/><child link="Steering_fr"/><axis xyz="0 0 1"/>
    <limit lower="${-steer_limit}" upper="${steer_limit}" effort="200" velocity="2.0"/>
    <dynamics damping="1.5" friction="0.1"/>
  </joint>

  <joint name="Wheel_fr_joint" type="continuous">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="Steering_fr"/><child link="Wheel_fr"/><axis xyz="0 1 0"/>
    <limit effort="300" velocity="100"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

</robot>